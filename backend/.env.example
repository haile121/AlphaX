NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

JWT_SECRET=dev-secret-change-me

# Database configuration (no DATABASE_URL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=amharic_cpp_platform

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AI Tutor — set at least one (Gemini is used first if both are set).
# Leave GEMINI_MODEL empty to auto-pick lite/flash models via ListModels. Set a name to lock one model.
# If Gemini hits quota, OPENAI_API_KEY is used when set.
GEMINI_API_KEY=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
